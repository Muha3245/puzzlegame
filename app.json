{
  "expo": {
    "name": "WordRush Arena",
    "slug": "wordrush-arena",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wordrush-arena-logo.png",
    "scheme": "wordrusharena",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#05091C",
        "foregroundImage": "./assets/images/wordrush-arena-logo.png",
        "backgroundImage": "./assets/images/wordrush-arena-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.muhammedali22.wordrusharena"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/wordrush-arena-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to set a profile picture.",
          "cameraPermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/wordrush-arena-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#05091C",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9f9dcd7-4f6b-45b2-ab1f-a11d335a5ce1"
      }
    }
  }
}
